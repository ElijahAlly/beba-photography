# --- Database ---
# Host-side default for `pnpm dev` (port 5433 from docker-compose).
# docker-compose.yml overrides this with `db:5432` for the in-container backend.
DATABASE_URL=postgres://user:password@localhost:5433/cinderella

# --- Redis (job queue, future use) ---
# Same pattern as DATABASE_URL: host-side default; docker-compose overrides.
REDIS_URL=redis://localhost:6380

# --- Identity Provider (mytrees.family OAuth2) ---
# Must match a client registered in family-trees' oauthClients table.
# Generate the client secret via `openssl rand -base64 32` and set BOTH:
#   - here as OAUTH_CLIENT_SECRET (and CINDERELLA_OAUTH_CLIENT_SECRET — same value)
#   - in family-trees .env as CINDERELLA_OAUTH_CLIENT_SECRET (must be identical)
#
# IDP_*_URL: point at *local* family-trees in dev, *production* mytrees.family in prod.
#   dev:  http://localhost:3000/oauth/authorize  etc.
#   prod: https://mytrees.family/oauth/authorize etc.
IDP_AUTHORIZE_URL=http://localhost:3000/oauth/authorize
IDP_TOKEN_URL=http://localhost:3000/api/oauth/token
IDP_USERINFO_URL=http://localhost:3000/api/oauth/userinfo
OAUTH_CLIENT_ID=cinderella
OAUTH_CLIENT_SECRET=gf/RaVf0VmQ1fq0YZTVh7909LLvlMPXDjKAXNwx0Pak=
# Backend has global prefix `api`, so callback path is /api/auth/callback.
#   dev:  http://localhost:3001/api/auth/callback
#   prod: https://cinderella.photography/api/auth/callback
OAUTH_REDIRECT_URI=http://localhost:3001/api/auth/callback
OAUTH_SCOPES=profile photos:read photos:write

# --- JWT (shared HS256 secret with mytrees.family + photos.mytrees.family) ---
# Must match byte-for-byte across all three apps. Generate via `openssl rand -base64 48`.
JWT_SECRET=gvs0EUdIp5lhW2gAgSvTGI5+xB6rLO/I6KACAUHs3cEQuf8M69dKywBkbqLtk91K

# --- Photos media backbone ---
PHOTOS_API_URL=https://photos.mytrees.family
PHOTOS_API_KEY=change-me-from-photos-app-API_KEYS

# --- Backend ---
BACKEND_PORT=3001
# Local dev: frontend runs on 3002 to avoid colliding with family-trees on 3000.
# Production: set to https://cinderella.photography
FRONTEND_ORIGIN=http://localhost:3002

# --- Frontend ---
NUXT_PUBLIC_API_BASE=http://localhost:3001

# --- Pricing (baseline packages; edit freely — NO prices live in code) ---
# Currency is an ISO code, not a price. Packages are a single-line JSON array.
# Each: { id, name, description, priceCents, unit: "flat"|"hour", featured?, startingAt? }
# Baselines: $150 30-min · $200 30-min+15 edits · $250/hr raw · $300/hr raw+edits
#            $350 proposal · $400/hr wedding · $500+ multi-photographer.
PRICING_CURRENCY=usd
PRICING_PACKAGES_JSON=[{"id":"mini","name":"Mini Session","description":"A focused 30-minute shoot.","priceCents":15000,"unit":"flat"},{"id":"mini_edited","name":"Mini + Edits","description":"30 minutes plus 15 hand-edited photos.","priceCents":20000,"unit":"flat","featured":true},{"id":"hourly_raw","name":"Hourly — Raw","description":"Every raw frame, billed by the hour.","priceCents":25000,"unit":"hour"},{"id":"hourly_edited","name":"Hourly — Raw + Edits","description":"All raw photos plus 15+ edits, per hour.","priceCents":30000,"unit":"hour"},{"id":"proposal","name":"Proposal","description":"Discreet coverage of the big question.","priceCents":35000,"unit":"flat"},{"id":"wedding","name":"Wedding","description":"Full wedding-day coverage, by the hour.","priceCents":40000,"unit":"hour"},{"id":"multi","name":"Multi-Photographer","description":"Two or more photographers.","priceCents":50000,"unit":"flat","startingAt":true}]

# --- Stripe (online payments) ---
# Leave blank to disable online payments (cash/waive still work).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Publishable key is safe to expose to the browser.
NUXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
