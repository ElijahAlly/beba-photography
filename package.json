{
  "name": "cinderella-photography",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build:packages": "pnpm -r --filter='./packages/*' run build",
    "build:apps": "pnpm -r --filter='./apps/*' run build",
    "build": "pnpm build:packages && pnpm build:apps",
    "dev:packages": "pnpm -r --parallel --filter='./packages/*' run build:watch",
    "dev": "pnpm build:packages && pnpm -r --parallel --filter='./apps/*' run dev",
    "db:push": "pnpm --filter @cinderella/database run db:push",
    "db:generate": "pnpm --filter @cinderella/database run db:generate"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
